{
  "appId": "com.flydecision",
  "appName": "Fly Decision",
  "webDir": "www", 
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "launchFadeOutDuration": 500,
      "backgroundColor": "#0086f4", 
      "androidSplashResourceName": "splash",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "Light",
      "backgroundColor": "#d9ebf9",
      "overlaysWebView": false
    }
  }
}